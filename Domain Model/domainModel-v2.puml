@startuml

enum UserRole {
  ADMIN
  PROFESSOR
  STUDENT
}

enum ResourceType {
  CLASS_MATERIAL
  ASSIGNMENT_STATEMENT
  SOLUTION
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  LATE
  GRADED
}

class User {
  +id: UUID
  +name: String
  +email: String
  +passwordHash: String
  +role: UserRole
  +active: boolean
}

class Course {
  +id: UUID
  +code: String
  +title: String
  +description: String
}

class Enrollment {
  +id: UUID
  +enrolledAt: DateTime
}

class ClassSession {
  +id: UUID
  +title: String
  +scheduledAt: DateTime
  +topic: String
}

class Resource {
  +id: UUID
  +title: String
  +type: ResourceType
  +filePath: String
  +uploadedAt: DateTime
}

class Assignment {
  +id: UUID
  +title: String
  +description: String
  +deadline: DateTime
}

class Submission {
  +id: UUID
  +submittedAt: DateTime
  +status: SubmissionStatus
  +filePath: String
}

class ChatRoom {
  +id: UUID
  +name: String
}

class ChatMessage {
  +id: UUID
  +content: String
  +sentAt: DateTime
}

User "1" -- "0..*" Enrollment
Course "1" -- "0..*" Enrollment

Course "1" -- "0..*" ClassSession
Course "1" -- "0..*" Resource
Course "1" -- "0..*" Assignment
Course "1" -- "1" ChatRoom

Assignment "1" -- "0..*" Submission
User "1" -- "0..*" Submission : submits >
User "1" -- "0..*" Resource : uploads >
User "1" -- "0..*" ChatMessage : sends >
ChatRoom "1" -- "0..*" ChatMessage

@enduml
