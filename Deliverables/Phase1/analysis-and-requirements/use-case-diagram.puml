@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor "User" as user
actor "Admin" as admin
actor "Professor" as teacher
actor "Student" as student

admin --|> user
teacher --|> user
student --|> user

rectangle "Learning Management System" {

  package "Identity & Access" {
    usecase "Login" as login
    usecase "Recover/Reset Password" as reset
    usecase "Create Users" as UC1
    usecase "Assign Roles" as UC2
  }

  package "Course & Content" {
    usecase "Manage Courses" as UC4
    usecase "Enroll in Course" as UC6
    usecase "View Enrolled Courses" as UC7
    usecase "Upload Course Materials" as UC8
    usecase "Access Materials" as UC9
  }

  package "Assignments & Grading" {
    usecase "Create Assignments" as UC10
    usecase "Submit Assignment" as UC12
    usecase "View Submissions" as UC13
    usecase "Grade & Feedback" as UC14
  }

  package "Communication" {
    usecase "Use Course Chat" as UC15
  }
}

' Ações comuns a todos (via User)
user -- login
user -- reset
user -- UC7
user -- UC15

admin -- UC1
admin -- UC2

teacher -- UC4
teacher -- UC8
teacher -- UC10
teacher -- UC13
teacher -- UC14

student -- UC6
student -- UC9
student -- UC12

@enduml