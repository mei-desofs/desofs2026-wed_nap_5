            },
            "data": {
              "type": "tm.BoundaryBox",
              "name": "LearningMore Backend Trust Boundary",
              "description": "Backend APIs, business logic, and controlled data stores for course management.",
              "isTrustBoundary": true,
              "hasOpenThreats": false,
              "crossingFlows": [],
              "containedElements": []
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000004",
            "shape": "process",
            "zIndex": 2,
            "position": {
              "x": 300,
              "y": 200
            },
            "size": {
              "width": 100,
              "height": 100
            },
            "data": {
              "type": "tm.Process",
              "name": "2.0 Validate Access",
              "description": "JWT validation, RBAC check, and enrollment verification for all course operations.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "System",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000001",
                  "number": 1,
                  "title": "Forged JWT bypasses course access control",
                  "description": "An attacker presents a forged or stolen JWT token claiming professor or student role and bypasses access validation for course operations.",
                  "mitigation": "Validate JWT signature using RSA public key, verify issuer, audience, expiry. Implement token revocation list (TRL) for compromised tokens. Use short-lived tokens (5-15 min) with refresh token rotation.",
                  "modelType": "STRIDE",
                  "type": "Spoofing",
                  "severity": "High",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000005",
            "shape": "process",
            "zIndex": 2,
            "position": {
              "x": 520,
              "y": 90
            },
            "size": {
              "width": 100,
              "height": 100
            },
            "data": {
              "type": "tm.Process",
              "name": "2.1 Create Course",
              "description": "Create course with metadata, schedule, and enrollment rules.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "Professor",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000006",
                  "number": 6,
                  "title": "Denial of service on course creation endpoint",
                  "description": "Attacker floods the course creation process with rapid requests causing service degradation.",
                  "mitigation": "Implement rate limiting: 10 courses per professor per hour. Use request throttling by JWT. Monitor endpoint response times. Implement circuit breaker pattern.",
                  "modelType": "STRIDE",
                  "type": "Denial of service",
                  "severity": "High",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000006",
            "shape": "process",
            "zIndex": 2,
            "position": {
              "x": 520,
              "y": 310
            },
            "size": {
              "width": 100,
              "height": 100
            },
            "data": {
              "type": "tm.Process",
              "name": "2.2 Manage Enrollment",
              "description": "Enroll student in course, validate prerequisites and capacity.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "Student",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000007",
                  "number": 7,
                  "title": "Denial of service on enrollment endpoint",
                  "description": "Attacker floods course enrollment process with bulk enrollment requests exhausting system resources.",
                  "mitigation": "Implement rate limiting per student: 5 enrollments per minute. Implement course capacity limits. Use queue-based enrollment for high-load courses. Monitor enrollment spike patterns.",
                  "modelType": "STRIDE",
                  "type": "Denial of service",
                  "severity": "High",
                  "status": "Open"
                },
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000010",
                  "number": 10,
                  "title": "Authorization bypass in enrollment validation",
                  "description": "Attacker bypasses enrollment prerequisites or capacity validation to enroll in restricted courses.",
                  "mitigation": "Validate prerequisites server-side before enrollment. Check course capacity dynamically. Verify enrollment rules match course definition. Implement two-phase commit for enrollment.",
                  "modelType": "STRIDE",
                  "type": "Elevation of privilege",
                  "severity": "High",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000007",
            "shape": "process",
            "zIndex": 2,
            "position": {
              "x": 760,
              "y": 200
            },
            "size": {
              "width": 100,
              "height": 100
            },
            "data": {
              "type": "tm.Process",
              "name": "2.3 Manage Sessions",
              "description": "Create and schedule class sessions for course.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "Professor",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000005",
                  "number": 5,
                  "title": "Course session schedule tampering",
                  "description": "Attacker modifies class session schedules, locations, or instructors without authorization.",
                  "mitigation": "Restrict session modifications to course owner professor. Validate session time against course schedule. Notify enrolled students of session changes. Log modifications with change audit trail.",
                  "modelType": "STRIDE",
                  "type": "Tampering",
                  "severity": "Medium",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000008",
            "shape": "process",
            "zIndex": 2,
            "position": {
              "x": 760,
              "y": 380
            },
            "size": {
              "width": 100,
              "height": 100
            },
            "data": {
              "type": "tm.Process",
              "name": "2.4 View Courses",
              "description": "Display enrolled courses and course details to student.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "Student",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000008",
                  "number": 8,
                  "title": "Unauthorized course information disclosure",
                  "description": "Attacker queries course view endpoint to retrieve restricted course information (roster, contact info, internal notes).",
                  "mitigation": "Implement field-level security: only show enrolled students their courses and basic info. Mask sensitive fields (internal notes). Validate student enrollment before returning course details.",
                  "modelType": "STRIDE",
                  "type": "Information disclosure",
                  "severity": "High",
                  "status": "Open"
                },
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000009",
                  "number": 9,
                  "title": "Course enrollment information leakage",
                  "description": "Attacker infers enrollment status or student count through response time analysis or error message differences.",
                  "mitigation": "Normalize response times for authorization failures. Use consistent error messages. Implement request obfuscation. Log authorization failures for anomaly detection.",
                  "modelType": "STRIDE",
                  "type": "Information disclosure",
                  "severity": "Medium",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000009",
            "shape": "store",
            "zIndex": 2,
            "position": {
              "x": 1010,
              "y": 90
            },
            "size": {
              "width": 170,
              "height": 80
            },
            "data": {
              "type": "tm.Store",
              "name": "Course Store",
              "description": "Persistent course data: metadata, enrollment records, class sessions, descriptions (encrypted).",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "isALog": false,
              "isEncrypted": true,
              "isSigned": false,
              "storesCredentials": false,
              "storesInventory": false,
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000003",
                  "number": 3,
                  "title": "Course data tampering - unauthorized modification",
                  "description": "Attacker modifies course metadata, schedule, or enrollment rules through compromised access or authorization bypass.",
                  "mitigation": "Implement row-level security at database layer. Validate all course modifications against course ownership. Log all updates with before/after values. Use database transactions with ACID guarantees.",
                  "modelType": "STRIDE",
                  "type": "Tampering",
                  "severity": "High",
                  "status": "Open"
                },
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000004",
                  "number": 4,
                  "title": "Unauthorized enrollment tampering",
                  "description": "Attacker modifies enrollment records to add/remove students from courses without authorization.",
                  "mitigation": "Enforce RBAC: only professors can modify enrollments for their courses. Validate enrollment capacity against course max enrollment. Log all enrollment changes with actor identification.",
                  "modelType": "STRIDE",
                  "type": "Tampering",
                  "severity": "High",
                  "status": "Open"
                },
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000015",
                  "number": 15,
                  "title": "Course Store data breach - sensitive information exposed",
                  "description": "Database breach exposes course metadata, enrollment records, professor contact information stored in Course Store.",
                  "mitigation": "Encrypt course data at rest using AES-256. Restrict database access with network segmentation. Implement database activity monitoring (DAM). Use role-based database access controls.",
                  "modelType": "STRIDE",
                  "type": "Information disclosure",
                  "severity": "High",
                  "status": "Open"
                },
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000016",
                  "number": 16,
                  "title": "SQL injection in course data queries",
                  "description": "Attacker injects SQL commands through course search or filter parameters to extract sensitive data.",
                  "mitigation": "Use parameterized queries (PreparedStatements) for all database operations. Implement input validation (whitelist course fields). Use ORM frameworks that escape queries. Implement WAF rules.",
                  "modelType": "STRIDE",
                  "type": "Tampering",
                  "severity": "High",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000010",
            "shape": "store",
            "zIndex": 2,
            "position": {
              "x": 1010,
              "y": 280
            },
            "size": {
              "width": 170,
              "height": 80
            },
            "data": {
              "type": "tm.Store",
              "name": "Audit Log",
              "description": "Immutable append-only log of course creation, enrollment changes, session scheduling, and view events (encrypted).",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "isALog": true,
              "isEncrypted": true,
              "isSigned": false,
              "storesCredentials": false,
              "storesInventory": false,
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000012",
                  "number": 12,
                  "title": "Audit trail tampering - course events not logged",
                  "description": "Attacker modifies or deletes audit log entries to hide unauthorized course modifications.",
                  "mitigation": "Store audit log in immutable append-only database. Use cryptographic hashing to detect tampering. Restrict audit log access to security team only. Replicate audit logs to external system.",
                  "modelType": "STRIDE",
                  "type": "Tampering",
                  "severity": "High",
                  "status": "Open"
                },
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000017",
                  "number": 17,
                  "title": "Audit log compromise - deletion or modification",
                  "description": "Attacker gains database access and modifies audit log entries to hide course modification traces.",
                  "mitigation": "Implement write-once read-many (WORM) storage for audit logs. Use cryptographic signing of audit entries. Monitor audit log for deletions. Replicate to off-site secure storage.",
                  "modelType": "STRIDE",
                  "type": "Tampering",
                  "severity": "High",
                  "status": "Open"
                }
              ]
            }
          },
