    "diagrams": [
      {
        "version": "2.4.1",
        "id": 0,
        "title": "Course Management",
        "description": "Professor creates courses and sessions, students enroll in courses and view course information with authorization, validation, and audit logging.",
        "diagramType": "STRIDE",
        "thumbnail": "./public/content/images/thumbnail.stride.jpg",
        "cells": [
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000001",
            "shape": "actor",
            "zIndex": 1,
            "position": {
              "x": 30,
              "y": 100
            },
            "size": {
              "width": 150,
              "height": 80
            },
            "data": {
              "type": "tm.Actor",
              "name": "Professor",
              "description": "Authenticated professor user creating courses and managing sessions.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "providesAuthentication": false,
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000002",
                  "number": 2,
                  "title": "Credential stuffing attacks on course access",
                  "description": "Attacker uses compromised credentials from external breaches to gain unauthorized access to course operations.",
                  "mitigation": "Implement account lockout after 5 failed attempts (15 min lockout). Require multi-factor authentication (MFA) for professor accounts. Monitor for credential reuse patterns.",
                  "modelType": "STRIDE",
                  "type": "Spoofing",
                  "severity": "High",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000002",
            "shape": "actor",
            "zIndex": 1,
            "position": {
              "x": 30,
              "y": 330
            },
            "size": {
              "width": 150,
              "height": 80
            },
            "data": {
              "type": "tm.Actor",
              "name": "Student",
              "description": "Authenticated student user enrolling in courses and viewing course information.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "providesAuthentication": false,
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-200000000014",
                  "number": 14,
                  "title": "Student denies course enrollment",
                  "description": "Student denies enrolling in course claiming unauthorized access, causing liability issues.",
                  "mitigation": "Capture enrollment requests with user confirmation. Log enrollment with student IP, browser fingerprint, timestamp. Require explicit student acknowledgment of course terms.",
                  "modelType": "STRIDE",
                  "type": "Repudiation",
                  "severity": "Medium",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-520000000003",
