@startuml
left to right direction
skinparam shadowing false

actor Admin

rectangle "1.1 Create User" as P11
rectangle "1.2 Update User" as P12
rectangle "1.3 Authenticate User" as P13
rectangle "1.4 Manage Roles" as P14

database "User Store" as DB

Admin --> P11 : Create user
Admin --> P12 : Update user
Admin --> P14 : Assign roles

P11 --> DB : Store User Aggregate
P12 --> DB : Update User data
P14 --> DB : Update role

P13 --> DB : Validate credentials
DB --> P13 : Auth result

P13 --> Admin : Login success/failure

@enduml