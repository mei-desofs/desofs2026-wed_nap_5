            "data": {
              "type": "tm.Process",
              "name": "3.3 Grade Submission",
              "description": "Reads submission data and stores grade plus feedback.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "Professor",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-100000000008",
                  "number": 8,
                  "title": "Grading endpoint overwhelmed",
                  "description": "Repeated grading requests degrade response time and block legitimate grading actions.",
                  "mitigation": "Use rate limits, bounded worker pools, and circuit breakers on grading APIs.",
                  "modelType": "STRIDE",
                  "type": "Denial of service",
                  "severity": "Medium",
                  "status": "Open"
                }
              ]
            }
          },
