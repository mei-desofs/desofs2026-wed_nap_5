            },
            "data": {
              "type": "tm.Process",
              "name": "3.2 Submit Assignment",
              "description": "Validates deadline and upload constraints, then persists submission file and metadata.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "Student",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-100000000003",
                  "number": 3,
                  "title": "Submission flood causes service degradation",
                  "description": "Automated repeated submissions exhaust upload workers and database connections.",
                  "mitigation": "Apply per-user/course rate limits, queue uploads, and enforce request throttling with backpressure.",
                  "modelType": "STRIDE",
                  "type": "Denial of service",
                  "severity": "Medium",
                  "status": "Open"
                }
              ]
            }
          },
          {
