            "data": {
              "type": "tm.Process",
              "name": "3.0 Validate Access + Enrollment",
              "description": "Validates JWT, role permissions, and course enrollment before allowing assignment actions.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "System",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-100000000001",
                  "number": 1,
                  "title": "Forged token bypasses access control",
                  "description": "An attacker presents a forged or stolen JWT and bypasses role and enrollment validation.",
                  "mitigation": "Validate token signature, issuer, audience and expiry; require short-lived tokens and revoke compromised sessions.",
                  "modelType": "STRIDE",
                  "type": "Spoofing",
                  "severity": "High",
                  "status": "Open"
                },
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-100000000002",
                  "number": 2,
                  "title": "Privilege escalation in authorization logic",
                  "description": "A logic flaw in RBAC/enrollment checks allows a student to execute professor-only actions.",
                  "mitigation": "Enforce deny-by-default authorization policy and centralize policy checks with test coverage for role boundaries.",
                  "modelType": "STRIDE",
                  "type": "Elevation of privilege",
                  "severity": "High",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-510000000005",
