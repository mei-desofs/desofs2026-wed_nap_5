            },
            "data": {
              "type": "tm.Process",
              "name": "3.1 Create Assignment",
              "description": "Creates assignment with title, description, and deadline.",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": true,
              "privilegeLevel": "Professor",
              "threats": [
                {
                  "threatId": "f70f9114-e8db-45f8-b4fb-100000000007",
                  "number": 7,
                  "title": "Assignment deadline tampering",
                  "description": "A malicious request manipulates assignment deadline or grading configuration parameters.",
                  "mitigation": "Apply strict server-side schema validation, immutable audit of deadline changes, and role-scoped update rules.",
                  "modelType": "STRIDE",
                  "type": "Tampering",
                  "severity": "High",
                  "status": "Open"
                }
              ]
            }
          },
          {
            "id": "8a31db7d-b7a4-47db-bf9b-510000000006",
